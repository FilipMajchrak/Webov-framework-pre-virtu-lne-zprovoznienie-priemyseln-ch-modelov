{
  "name": "simulator-oneexe",
  "version": "1.1.0",
  "private": true,
  "bin": "index.js",
  "dependencies": {
    "express": "^4.19.2",
    "modbus-serial": "^8.0.21-no-serial-port",
    "ws": "^8.18.3"
  },
  "devDependencies": {
    "pkg": "^5.8.1"
  },
  "scripts": {
    "start": "node index.js",
    "pack:win": "pkg . --targets node18-win-x64 --output simulator.exe"
  },
  "pkg": {
    "assets": [
      "simulator.html",
      "index.html",
      "PLC.js",
      "scripts/**/*",
      "sim_scripts/**/*",
      "style/**/*",
      "obj/**/*",
      "physi/**/*"
    ]
  }
}
